{
  "slug": "hortusfox",
  "title": "HortusFox",
  "description": "Self-hosted collaborative plant management system for tracking, organizing and caring for your indoor and outdoor plants.",
  "source": "https://github.com/danielbrendel/hortusfox-web",
  "website": "https://www.hortusfox.com",
  "icon": "https://raw.githubusercontent.com/stackblaze/stack-templates/main/services/hortusfox/icon.png",
  "categories": [
    "productivity",
    "collaboration",
    "utilities"
  ],
  "installation": "Image: ghcr.io/danielbrendel/hortusfox-web (official). Uses MariaDB (the mariadb add-on, host hortusfox-mysql). Rotate the MariaDB password (default 'hortusfox') and set a strong APP_ADMIN_PASSWORD (default placeholder) before exposing publicly; the first-run admin account is seeded from APP_ADMIN_EMAIL / APP_ADMIN_PASSWORD on initial migration. DB_CHARSET must be utf8mb4. Persistent volumes hold uploaded plant images (/var/www/html/public/img), backups (/var/www/html/public/backup), custom themes (/var/www/html/public/themes), app logs (/var/www/html/app/logs) and applied migration markers (/var/www/html/app/migrations) so data and migration state survive restarts. Set APP_TIMEZONE to your timezone.",
  "screenshots": [
    "https://www.hortusfox.com/img/screenshot.png"
  ],
  "links": [
    "https://github.com/danielbrendel/hortusfox-web/blob/master/README.md"
  ],
  "license": "MIT License",
  "spdx_id": "MIT",
  "stars": 1600,
  "language": "PHP",
  "image": {
    "repository": "ghcr.io/danielbrendel/hortusfox-web",
    "tag": "latest",
    "containerPort": "8080",
    "command": []
  },
  "envVars": [
    {
      "name": "APP_ADMIN_EMAIL",
      "value": "admin@example.com"
    },
    {
      "name": "APP_ADMIN_PASSWORD",
      "value": "replace-with-openssl-rand-hex-32"
    },
    {
      "name": "APP_TIMEZONE",
      "value": "UTC"
    },
    {
      "name": "DB_HOST",
      "value": "hortusfox-mysql"
    },
    {
      "name": "DB_PORT",
      "value": "3306"
    },
    {
      "name": "DB_DATABASE",
      "value": "hortusfox"
    },
    {
      "name": "DB_USERNAME",
      "value": "hortusfox"
    },
    {
      "name": "DB_PASSWORD",
      "value": "hortusfox"
    },
    {
      "name": "DB_CHARSET",
      "value": "utf8mb4"
    }
  ],
  "addons": [
    {
      "type": "mariadb",
      "name": "hortusfox",
      "db": "hortusfox",
      "user": "hortusfox",
      "password": "hortusfox"
    }
  ],
  "extraVolumes": [
    {
      "mountPath": "/var/www/html/public/img",
      "name": "hortusfox-images",
      "size": "5Gi"
    },
    {
      "mountPath": "/var/www/html/public/backup",
      "name": "hortusfox-backup",
      "size": "2Gi"
    },
    {
      "mountPath": "/var/www/html/public/themes",
      "name": "hortusfox-themes",
      "size": "1Gi"
    },
    {
      "mountPath": "/var/www/html/app/logs",
      "name": "hortusfox-logs",
      "size": "1Gi"
    },
    {
      "mountPath": "/var/www/html/app/migrations",
      "name": "hortusfox-migrate",
      "size": "1Gi"
    }
  ]
}
