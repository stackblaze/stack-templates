{
  "slug": "wger",
  "title": "Wger",
  "description": "Self-hosted FLOSS fitness and workout manager that lets you track workouts, nutrition, body weight, and exercises.",
  "source": "https://github.com/wger-project/wger",
  "website": "https://wger.de",
  "icon": "https://raw.githubusercontent.com/stackblaze/stack-templates/main/services/wger/icon.png",
  "categories": [
    "productivity",
    "utilities",
    "data"
  ],
  "installation": "Single-container Django app served via gunicorn on port 8000. Rotate SECRET_KEY and SIGNING_KEY (each a unique 50-char random string; they MUST differ) and the postgres password before going to production. Companion services deployed as add-ons: PostgreSQL (primary DB) and a Valkey (Redis-protocol) instance used for both the Django cache and the Celery broker/backend. Migrations run automatically on boot (DJANGO_PERFORM_MIGRATIONS=True). On first run an admin user 'admin' (password 'adminadmin') is created via DJANGO_DB_BOOTSTRAP_USER defaults; change it immediately. Set CSRF_TRUSTED_ORIGINS / SITE_URL to your real https URL (templated below). Uploaded media and static files persist on the mounted volume. Note: the periodic exercise/ingredient sync tasks run via Celery against the Valkey add-on; no separate worker pod is templated, so heavy background sync may be limited.",
  "screenshots": [],
  "links": [
    "https://wger.readthedocs.io/en/latest/production/docker.html"
  ],
  "license": "GNU Affero General Public License v3.0",
  "spdx_id": "AGPL-3.0",
  "stars": 4800,
  "language": "Python",
  "image": {
    "repository": "wger/server",
    "tag": "latest",
    "containerPort": "8000",
    "command": []
  },
  "envVars": [
    {
      "name": "SECRET_KEY",
      "value": "replace-with-openssl-rand-hex-32-50chars"
    },
    {
      "name": "SIGNING_KEY",
      "value": "replace-with-different-openssl-rand-hex-32"
    },
    {
      "name": "DJANGO_DEBUG",
      "value": "False"
    },
    {
      "name": "DJANGO_DB_ENGINE",
      "value": "django.db.backends.postgresql"
    },
    {
      "name": "DJANGO_DB_DATABASE",
      "value": "wger"
    },
    {
      "name": "DJANGO_DB_USER",
      "value": "wger"
    },
    {
      "name": "DJANGO_DB_PASSWORD",
      "value": "wger"
    },
    {
      "name": "DJANGO_DB_HOST",
      "value": "wger-postgresql-rw"
    },
    {
      "name": "DJANGO_DB_PORT",
      "value": "5432"
    },
    {
      "name": "DJANGO_PERFORM_MIGRATIONS",
      "value": "True"
    },
    {
      "name": "DJANGO_CACHE_BACKEND",
      "value": "django_redis.cache.RedisCache"
    },
    {
      "name": "DJANGO_CACHE_LOCATION",
      "value": "redis://rfr-wger-valkey-readwrite:6379/1"
    },
    {
      "name": "DJANGO_CACHE_CLIENT_CLASS",
      "value": "django_redis.client.DefaultClient"
    },
    {
      "name": "DJANGO_CACHE_TIMEOUT",
      "value": "1296000"
    },
    {
      "name": "USE_CELERY",
      "value": "True"
    },
    {
      "name": "CELERY_BROKER",
      "value": "redis://rfr-wger-valkey-readwrite:6379/2"
    },
    {
      "name": "CELERY_BACKEND",
      "value": "redis://rfr-wger-valkey-readwrite:6379/2"
    },
    {
      "name": "SITE_URL",
      "value": "{{KUBERO_APP_URL}}"
    },
    {
      "name": "CSRF_TRUSTED_ORIGINS",
      "value": "{{KUBERO_APP_URL}}"
    },
    {
      "name": "ALLOWED_HOSTS",
      "value": "*"
    },
    {
      "name": "X_FORWARDED_PROTO_HEADER_SET",
      "value": "True"
    },
    {
      "name": "MEDIA_ROOT",
      "value": "/home/wger/media"
    },
    {
      "name": "STATIC_ROOT",
      "value": "/home/wger/static"
    }
  ],
  "addons": [
    {
      "type": "postgres",
      "name": "wger",
      "db": "wger",
      "user": "wger",
      "password": "wger"
    },
    {
      "type": "valkey",
      "name": "wger"
    }
  ],
  "extraVolumes": [
    {
      "mountPath": "/home/wger/media",
      "name": "wger-media",
      "size": "5Gi"
    }
  ]
}
