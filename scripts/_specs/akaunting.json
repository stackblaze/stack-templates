{
  "slug": "akaunting",
  "title": "Akaunting",
  "description": "Free and open-source online accounting software for small businesses and freelancers, with invoicing, expense tracking, and reporting.",
  "source": "https://github.com/akaunting/akaunting",
  "website": "https://akaunting.com",
  "icon": "https://raw.githubusercontent.com/stackblaze/stack-templates/main/services/akaunting/icon.png",
  "categories": [
    "finance",
    "erp",
    "work"
  ],
  "installation": "Akaunting is a Laravel app backed by MariaDB/MySQL (it does NOT support Postgres). On first boot the entrypoint installs the schema and seeds the admin user from ADMIN_EMAIL/ADMIN_PASSWORD, then the web installer is bypassed. Rotate the MariaDB password (default 'akaunting'), ADMIN_PASSWORD, and APP_KEY (must be a 32-char value; the placeholder is intentionally weak — regenerate with 'php artisan key:generate' or set base64:<openssl rand -base64 32>). After the DB add-on is healthy, log in at the app URL with ADMIN_EMAIL/ADMIN_PASSWORD and change the admin password immediately. Uploaded files, generated PDFs, and logos persist under /var/www/html/storage (mounted volume).",
  "screenshots": [],
  "links": [
    "https://akaunting.com/hc/docs/on-premise/installation/",
    "https://github.com/akaunting/docker"
  ],
  "license": "GNU General Public License v3.0",
  "spdx_id": "GPL-3.0",
  "stars": 8600,
  "language": "PHP",
  "image": {
    "repository": "akaunting/akaunting",
    "tag": "latest",
    "containerPort": "8080",
    "command": []
  },
  "envVars": [
    {
      "name": "APP_URL",
      "value": "{{KUBERO_APP_URL}}"
    },
    {
      "name": "APP_ENV",
      "value": "production"
    },
    {
      "name": "APP_DEBUG",
      "value": "false"
    },
    {
      "name": "APP_KEY",
      "value": "base64:replace-with-openssl-rand-base64-32"
    },
    {
      "name": "APP_LOCALE",
      "value": "en-US"
    },
    {
      "name": "DB_CONNECTION",
      "value": "mysql"
    },
    {
      "name": "DB_HOST",
      "value": "akaunting-mysql"
    },
    {
      "name": "DB_PORT",
      "value": "3306"
    },
    {
      "name": "DB_DATABASE",
      "value": "akaunting"
    },
    {
      "name": "DB_USERNAME",
      "value": "akaunting"
    },
    {
      "name": "DB_PASSWORD",
      "value": "akaunting"
    },
    {
      "name": "DB_PREFIX",
      "value": "ak_"
    },
    {
      "name": "COMPANY_NAME",
      "value": "My Company"
    },
    {
      "name": "COMPANY_EMAIL",
      "value": "admin@example.com"
    },
    {
      "name": "ADMIN_EMAIL",
      "value": "admin@example.com"
    },
    {
      "name": "ADMIN_PASSWORD",
      "value": "replace-with-strong-password"
    }
  ],
  "addons": [
    {
      "type": "mariadb",
      "name": "akaunting",
      "db": "akaunting",
      "user": "akaunting",
      "password": "akaunting"
    }
  ],
  "extraVolumes": [
    {
      "mountPath": "/var/www/html/storage",
      "name": "akaunting-data",
      "size": "2Gi"
    }
  ]
}
