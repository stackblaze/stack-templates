{
  "viewport": { "width": 1920, "height": 1080 },
  "deviceScaleFactor": 2,
  "login": {
    "path": "/auth?redirect=%2F",
    "steps": [
      { "fill": { "#email": "${OPEN_WEBUI_EMAIL}" } },
      { "fill": { "#password": "${OPEN_WEBUI_PASSWORD}" } },
      { "evaluate": "document.querySelector('button[type=\"submit\"]')?.click()" },
      { "waitForNavigation": true },
      { "click": "button:has-text(\"Okay, Let's Go!\")" }
    ],
    "waitAfterMs": 2000
  },
  "pages": [
    { "name": "home", "path": "/", "waitMs": 2500 },
    { "name": "models", "path": "/workspace/models", "waitMs": 2500 },
    { "name": "admin", "path": "/admin/users/overview", "waitMs": 2500 },
    { "name": "connections", "path": "/admin/settings/connections", "waitMs": 2500 }
  ]
}
