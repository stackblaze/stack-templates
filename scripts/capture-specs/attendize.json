  "login": {
    "path": "/login",
    "steps": [
      { "fill": { "input[name='email'], #email": "admin@example.com" } },
      { "fill": { "input[name='password'], #password": "changeme" } },
      { "click": "button[type='submit'], input[type='submit'], .btn-login" },
